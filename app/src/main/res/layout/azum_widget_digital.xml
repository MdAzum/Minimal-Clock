<?xml version="1.0" encoding="utf-8"?>
<!-- Azum Digital Clock Widget layout -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/azum_digital_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/azum_widget_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <TextClock
            android:id="@+id/azum_digital_widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="h:mm"
            android:format24Hour="HH:mm"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp"
            android:fontFamily="sans-serif-light" />

        <TextClock
            android:id="@+id/azum_digital_widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:format12Hour="EEE, MMM d"
            android:format24Hour="EEE, MMM d"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</FrameLayout>
