<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AzumClock"
        android:dataExtractionRules="@xml/azum_data_extraction_rules"
        android:fullBackupContent="@xml/azum_backup_rules">

        <!-- Main full-screen clock screen -->
        <activity
            android:name="com.azum.clock.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AzumClock">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Azum minimalist digital clock widget -->
        <receiver
            android:name="com.azum.clock.widget.AzumDigitalWidgetProvider"
            android:exported="true"
            android:label="@string/azum_digital_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/azum_digital_widget_info" />
        </receiver>

        <!-- Azum minimalist analog clock widget -->
        <receiver
            android:name="com.azum.clock.widget.AzumAnalogWidgetProvider"
            android:exported="true"
            android:label="@string/azum_analog_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/azum_analog_widget_info" />
        </receiver>

        <!-- Azum icon-style live clock widget (1x1, sits in the app icon grid) -->
        <receiver
            android:name="com.azum.clock.widget.AzumIconWidgetProvider"
            android:exported="true"
            android:label="@string/azum_icon_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/azum_icon_widget_info" />
        </receiver>

    </application>

</manifest>
